{
  "name": "titanic-expedition",
  "version": "0.1.0",
  "description": "Mode-aware schema projection for TypeScript, inspired by pydantic-extension.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage .vitest-cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run clean && npm run test && npm run build"
  },
  "keywords": [
    "typescript",
    "zod",
    "schema",
    "projection",
    "governance",
    "llm",
    "serialization"
  ],
  "author": "OpenAI",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.0",
    "zod": "^4.0.0"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "dependencies": {
    "assertion-error": "^2.0.1",
    "chai": "^6.2.2",
    "convert-source-map": "^2.0.0",
    "detect-libc": "^2.1.2",
    "es-module-lexer": "^2.0.0",
    "estree-walker": "^3.0.3",
    "expect-type": "^1.3.0",
    "fdir": "^6.5.0",
    "lightningcss": "^1.32.0",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "lightningcss-linux-x64-musl": "^1.32.0",
    "magic-string": "^0.30.21",
    "nanoid": "^3.3.11",
    "obug": "^2.1.1",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.8",
    "rolldown": "^1.0.0-rc.12",
    "siginfo": "^2.0.0",
    "source-map-js": "^1.2.1",
    "stackback": "^0.0.2",
    "std-env": "^4.0.0",
    "tinybench": "^2.9.0",
    "tinyexec": "^1.0.4",
    "tinyglobby": "^0.2.15",
    "tinyrainbow": "^3.1.0",
    "vite": "^8.0.3",
    "why-is-node-running": "^2.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/humblemat810/titanic-expedition.git"
  },
  "bugs": {
    "url": "https://github.com/humblemat810/titanic-expedition/issues"
  },
  "homepage": "https://github.com/humblemat810/titanic-expedition#readme"
}
